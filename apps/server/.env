# WebContainer / local dev: leave PROD unset. The app runs in-memory.
# Deployment ONLY: hosting platform (Render/etc.) sets PROD=true + MONGODB_URI.
# Do NOT commit a real MONGODB_URI here — db.ts ignores it unless PROD=true anyway.
# PROD=true
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/mydb
# PORT=3001
